{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$(git rev-parse --show-toplevel)/.codex/hooks/block-prod-destructive-sql.sh", "statusMessage": "Checking for destructive prod SQL" },
          { "type": "command", "command": "$(git rev-parse --show-toplevel)/.codex/hooks/block-prod-artisan.sh", "statusMessage": "Checking for prod-affecting artisan" }
        ]
      },
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          { "type": "command", "command": "$(git rev-parse --show-toplevel)/.codex/hooks/protect-env-files.sh", "statusMessage": "Protecting .env / secret files" }
        ]
      }
    ]
  }
}
